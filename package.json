{
	"name": "librgrn",
	"version": "1.1.0",
	"description": "Pure Node.js cryptographic random & security utilities",
	"keywords": [
		"random",
		"cryptography",
		"security",
		"jwt",
		"crypto",
		"token"
	],
	"homepage": "https://github.com/neuxdotdev/libgrnd#readme",
	"bugs": {
		"url": "https://github.com/neuxdotdev/libgrnd/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/neuxdotdev/libgrnd.git"
	},
	"license": "AGPL-3.0",
	"author": "neuxdotdev",
	"type": "module",
	"main": "./build/lib.cjs",
	"module": "./build/lib.js",
	"types": "./build/lib.d.ts",
	"exports": {
		".": {
			"types": "./build/lib.d.ts",
			"import": "./build/lib.js",
			"require": "./build/lib.cjs"
		}
	},
	"files": [
		"build"
	],
	"sideEffects": false,
	"engines": {
		"node": ">=24"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"clean": "rm -rf {dist,build}",
		"typecheck": "tsc --noEmit",
		"build:ts": "tsc",
		"build:types": "dts-bundle-generator -o dist/lib.d.ts dist/lib.d.ts",
		"build:bundle": "rollup -c",
		"build": "npm run clean && npm run typecheck && npm run build:ts && npm run build:bundle",
		"build:prod": "NODE_ENV=production npm run build",
		"dev": "rollup -c -w --bundleConfigAsCjs",
		"dev:types": "tsc --emitDeclarationOnly --outDir dist --watch",
		"format:build": "node scripts/format-build.js",
		"lint": "tsc --noEmit",
		"format": "prettier . --write",
		"format:check": "prettier . --check",
		"clean-code": "rmcm -l js -i -c 0 -r ./src --verbose && npm run format",
		"rebuild": "npm run clean && npm run clean-code && npm run build && npm run format:build",
		"test": "node --test",
		"prepublishOnly": "npm run build",
		"prepare": "husky install"
	},
	"dependencies": {
		"@types/rollup-plugin-peer-deps-external": "^2.2.6",
		"jsonwebtoken": "^9.0.3"
	},
	"devDependencies": {
		"@rollup/plugin-commonjs": "^29.0.0",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@rollup/plugin-terser": "^0.4.4",
		"@rollup/plugin-typescript": "^12.3.0",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^25.3.3",
		"dts-bundle-generator": "^9.5.1",
		"esbuild": "^0.27.3",
		"eslint": "^10.0.2",
		"husky": "^9.1.7",
		"prettier": "^3.8.1",
		"rollup": "^4.59.0",
		"rollup-plugin-dts": "^6.3.0",
		"rollup-plugin-peer-deps-external": "^2.2.4",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
